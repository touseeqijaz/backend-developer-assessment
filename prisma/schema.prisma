generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  sales     Sale[]
  targets   Target[]
  createdAt DateTime  @default(now())
}

model Sale {
  id        Int       @id @default(autoincrement())
  amount    Float
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime  @default(now())
}

model Target {
  id            Int       @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id])
  userId        Int
  month         Int
  year          Int
  target_amount Float
}

model RegionAssignment {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  region     String
  start_date DateTime
  end_date   DateTime?
}